# Server port
PORT=8080

# Frontend URL for CORS (leave empty to allow all origins in dev)
# ALLOWED_ORIGIN=https://your-app.onrender.com

# Path to built React static files (leave empty in dev, set in production)
# STATIC_DIR=/public

# SQLite database path (defaults to ./data/ace_reaction.db)
# DB_PATH=./data/ace_reaction.db

# Game timing (all values in milliseconds)
ACE_CLICK_TIMEOUT_MS=3000    # How long players have to click when an Ace appears
CARD_FLIP_MIN_DELAY_MS=1500  # Min delay between non-Ace card flips
CARD_FLIP_MAX_DELAY_MS=3000  # Max delay between non-Ace card flips
ROUND_END_DELAY_MS=2000      # Pause between rounds

# Game rules
ROUNDS_TO_WIN=3              # Rounds needed to win the game
TRIGGER_RANK=A               # Card rank that triggers a slap (A, K, Q, J, 2-10)
